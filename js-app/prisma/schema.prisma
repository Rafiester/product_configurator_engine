generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id         String    @id @default(uuid())
  name       String
  category   String
  qty        Int
  sdp        Decimal
  page_price Decimal
  srp        Decimal
  status     String    @default("active") // "active" or "inactive"
  
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  configurators ConfiguratorProductMapping[]

  @@map("products")
}

model Configurator {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("active") // "active" or "inactive"
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products ConfiguratorProductMapping[]

  @@map("configurators")
}

model ConfiguratorProductMapping {
  id              String       @id @default(uuid())
  configuratorId  String       @map("configurator_id")
  productId       String       @map("product_id")
  category        String
  qty             Int
  sdp             Decimal
  totalSdp        Decimal      @map("total_sdp")
  pagePrice       Decimal      @map("page_price")
  srp             Decimal
  margin          Decimal
  marginPercentage Decimal     @map("margin_percentage")
  
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  configurator Configurator @relation(fields: [configuratorId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("configurator_product_mappings")
}
